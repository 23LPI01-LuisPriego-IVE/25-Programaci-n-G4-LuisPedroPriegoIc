internal class Program
{
    private static void Main(string[] args)
    {
        Console.WriteLine("--- Clasificador de Triángulos ---");
        
        Console.Write("Ingrese la medida del primer lado: ");
        double lado1 = double.Parse(Console.ReadLine());

        Console.Write("Ingrese la medida del segundo lado: ");
        double lado2 = double.Parse(Console.ReadLine());

        Console.Write("Ingrese la medida del tercer lado: ");
        double lado3 = double.Parse(Console.ReadLine());

        // Evaluación del tipo de triángulo
        if (lado1 == lado2 && lado2 == lado3)
        {
            Console.WriteLine("Resultado: Es un triángulo Equilátero (todos sus lados son iguales).");
        }
        else if (lado1 == lado2 || lado1 == lado3 || lado2 == lado3)
        {
            Console.WriteLine("Resultado: Es un triángulo Isósceles (dos de sus lados son iguales).");
        }
        else
        {
            Console.WriteLine("Resultado: Es un triángulo Escaleno (todos sus lados son distintos).");
        }
    }
}

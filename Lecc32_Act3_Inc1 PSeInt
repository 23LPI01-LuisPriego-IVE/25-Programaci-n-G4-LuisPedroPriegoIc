Algoritmo Lecc32_Act3_Inc1
    Definir lado1, lado2, lado3 Como Real
    // Alumno: Luis Pedro Priego Ic 
    // Grado: 4to Bachillerato en Computación 
    // Colegio Salesiano Don Bosco 
    // Docente: Eliezer Crup
    
    Escribir "--- Clasificador de Triángulos ---"
    
    Escribir Sin Saltar "Ingrese la medida del primer lado: "
    Leer lado1
    
    Escribir Sin Saltar "Ingrese la medida del segundo lado: "
    Leer lado2
    
    Escribir Sin Saltar "Ingrese la medida del tercer lado: "
    Leer lado3
    
    // Evaluación del tipo de triángulo
    Si lado1 = lado2 Y lado2 = lado3 Entonces
        Escribir "Resultado: Es un triángulo Equilátero (todos sus lados son iguales)."
    SiNo
        Si lado1 = lado2 O lado1 = lado3 O lado2 = lado3 Entonces
            Escribir "Resultado: Es un triángulo Isósceles (dos de sus lados son iguales)."
        SiNo
            Escribir "Resultado: Es un triángulo Escaleno (todos sus lados son distintos)."
        FinSi
    FinSi
FinAlgoritmo

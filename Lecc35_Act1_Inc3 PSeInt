Algoritmo Lecc35_Act1_Inc3
    Definir usuario, pc Como Entero
    Definir resp, opcUsuarioStr, opcPCStr Como Cadena
    // Alumno: Luis Pedro Priego Ic 
    // Grado: 4to Bachillerato en Computación 
    // Colegio Salesiano Don Bosco 
    // Docente: Eliezer Crup

    
    Repetir
        Escribir ""
        Escribir "--- PIEDRA, PAPEL O TIJERAS ---"
        Escribir "1. Piedra"
        Escribir "2. Papel"
        Escribir "3. Tijeras"
        Escribir Sin Saltar "Elige una opción (1-3): "
        Leer usuario
        
        Si usuario >= 1 Y usuario <= 3 Entonces
            // La computadora elige un número al azar entre 1 y 3
            pc = Aleatorio(1, 3)
            
            // Asignar el texto correspondiente a la elección del usuario
            Segun usuario Hacer
                1: opcUsuarioStr = "Piedra"
                2: opcUsuarioStr = "Papel"
                3: opcUsuarioStr = "Tijeras"
            FinSegun
            
            // Asignar el texto correspondiente a la elección de la computadora
            Segun pc Hacer
                1: opcPCStr = "Piedra"
                2: opcPCStr = "Papel"
                3: opcPCStr = "Tijeras"
            FinSegun
            
            Escribir ""
            Escribir "Tú elegiste: ", opcUsuarioStr
            Escribir "La computadora eligió: ", opcPCStr
            
            // Lógica para determinar el ganador
            Si usuario = pc Entonces
                Escribir "Resultado: ¡Es un empate!"
            SiNo
                Si (usuario = 1 Y pc = 3) O (usuario = 2 Y pc = 1) O (usuario = 3 Y pc = 2) Entonces
                    Escribir "Resultado: ¡Felicidades, ganaste!"
                SiNo
                    Escribir "Resultado: La computadora gana."
                FinSi
            FinSi
        SiNo
            Escribir "Opción no válida."
        FinSi
        
        Escribir ""
        Escribir Sin Saltar "¿Deseas jugar de nuevo? (s/n): "
        Leer resp
        
    // El ciclo continúa mientras la respuesta sea "s"
    Hasta Que Minusculas(resp) <> "s"
FinAlgoritmo

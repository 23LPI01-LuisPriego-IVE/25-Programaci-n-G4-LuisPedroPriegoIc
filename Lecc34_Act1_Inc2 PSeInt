Algoritmo Lecc34_Act1_Inc2
    // Alumno: Luis Pedro Priego Ic 
    // Grado: 4to Bachillerato en Computación 
    // Colegio Salesiano Don Bosco 
    // Docente: Eliezer Crup

    Definir peso, altura, imc Como Real
    
    Escribir Sin Saltar "Peso en kg: "
    Leer peso
    
    Escribir Sin Saltar "Altura en metros: "
    Leer altura
    
    imc = peso / (altura * altura)
    
    Escribir "Tu IMC es: ", imc
FinAlgoritmo

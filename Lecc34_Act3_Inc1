internal class Program
{
    private static void Main(string[] args)
    {
        Console.Write("Ingrese la cantidad en grados centígrados: ");
        double centigrados = double.Parse(Console.ReadLine());

        // Fórmulas de conversión
        double fahrenheit = (centigrados * 9 / 5) + 32;
        double celsius = centigrados; // Centígrados y Celsius son la misma escala
        double kelvin = centigrados + 273.15;

        Console.WriteLine("\n--- Resultados de la conversión ---");
        Console.WriteLine("a. Fahrenheit: " + fahrenheit);
        Console.WriteLine("b. Celsius: " + celsius);
        Console.WriteLine("c. Kelvin: " + kelvin);
    }
}
